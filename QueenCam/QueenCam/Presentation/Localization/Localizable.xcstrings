    },
    "깔끔하게 지웠어요." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Removed all"
          }
        }
      }
    },
    "내 기기로 사진을 촬영해요.\n동시에 친구에게 화면을 실시간으로 공유합니다." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take a photo with my phone.\nYou will share your screen."
          }
        }
      }
    },
    "내 기기로 찍고 있어요" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take a photo with my phone"
          }
        }
      }
    },
    "내가 사진 속 주인공이에요.\n카메라 속 내 모습을 실시간으로 볼 수 있어요." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Become the model of your photos.\nYou can see yourself being photographed."
          }
        }
      }
    },
    "다른 기기와 연결이 잘 안 안돼요." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I’m having trouble connecting to other devices."
          }
        }
      }
    },
