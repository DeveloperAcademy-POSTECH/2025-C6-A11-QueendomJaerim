    },
    "로그 내보내기" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Export log"
          }
        }
      }
    },
    "로그 파일을 불러오고 있습니다." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loading log file…"
          }
        }
      }
    },
    "매번 기기 검색 후, 연결을 해야하는지 궁금해요." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I’m wondering if I need to find nearby devices and connect every time."
          }
        }
      }
    },
    "매직펜" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Magic Pen"
          }
        }
      }
    },
    "모델" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Model"
          }
        }
      }
    },
    "모델 가이드" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Guide for model"
          }
        }
      }
    },
    "버전 정보" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Version"
          }
        }
      }
    },
    "사진 보관함에 접근할 수 없어요. \n설정에서 사진 보관함 접근을 허용해주세요." : {
